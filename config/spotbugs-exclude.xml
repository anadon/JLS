<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs baseline for JLS.

  Everything excluded here is a KNOWN, intentionally deferred finding.
  New findings of any other kind fail the build (threshold High, see pom.xml).
  Shrink this file over time; do not add to it to silence a new bug.
-->
<FindBugsFilter>

  <!-- Deliberate global state in the load path: JLSInfo.loadError and the
       Circuit.lineNumber load cursor are written by instance loaders, and
       Constant remembers previous dialog settings in statics. Scoped to
       exactly the classes that trip the detector today (issue #54) so any
       NEW static-write-from-instance-method elsewhere fails the build.
       Every new entry in this file MUST carry a Class scope. -->
  <Match>
    <Class name="jls.Circuit"/>
    <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
  </Match>
  <Match>
    <Class name="jls.edit.CircuitSnapshot"/>
    <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
  </Match>
  <Match>
    <Class name="jls.elem.Constant"/>
    <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
  </Match>

  <!-- DefaultExceptionHandler frees a ballast allocation and explicitly GCs
       inside the OutOfMemoryError handler so the error dialog has headroom.
       A legitimate System.gc() use. -->
  <Match>
    <Class name="jls.DefaultExceptionHandler"/>
    <Bug pattern="DM_GC"/>
  </Match>

</FindBugsFilter>
